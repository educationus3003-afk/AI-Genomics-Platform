Bootstrap: docker
From: ubuntu:24.04

%post
    apt-get update

    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        bash \
        bcftools \
        samtools \
        tabix \
        bedtools \
        python3 \
        python3-pip \
        python3-venv \
        python3-pandas \
        openjdk-17-jre-headless \
        perl \
        git \
        wget \
        curl \
        unzip \
        tar \
        make \
        gcc \
        g++ \
        gawk \
        sed \
        coreutils \
        ca-certificates

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec "$@"

%test
    bcftools --version
    samtools --version
    python3 --version
    java -version
