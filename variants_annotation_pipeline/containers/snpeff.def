Bootstrap: docker
From: ubuntu:24.04

%post
    apt-get update

    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        openjdk-21-jre-headless \
        wget \
        unzip \
        ca-certificates

    cd /opt

    wget https://snpeff-public.s3.amazonaws.com/versions/snpEff_latest_core.zip

    unzip snpEff_latest_core.zip

    rm snpEff_latest_core.zip

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export SNPEFF_HOME=/opt/snpEff

%runscript
    exec java -jar /opt/snpEff/snpEff.jar "$@"

%test
    java -version
    java -jar /opt/snpEff/snpEff.jar -version
